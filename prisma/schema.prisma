generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model reports {
  id             String   @id @default(uuid()) @db.Uuid
  repoName       String
  repoUrl        String
  techStack      Json
  summaryMetrics Json
  fileFindings   Json
  topIssues      Json
  score          Int
  scoreGrade     String
  scoreBreakdown Json
  aiReport       String?
  warnings       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model feedback {
  id        Int      @id @default(autoincrement())
  reportId  String   @db.Uuid
  rating    String
  message   String?
  createdAt DateTime @default(now())
}
